# ---------- Env / local overrides ----------
# NOTE: this project ships dev defaults INLINE in docker-compose.yml on purpose,
# so `git clone && docker compose up` works with zero extra steps.
# These ignores only guard against accidental local secret files.
*.env.local
.env.*.local
frontend/.env.local
backend/src/**/appsettings.*.Local.json

